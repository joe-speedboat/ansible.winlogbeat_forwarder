# {{ ansible_managed }}
# Winlogbeat configuration — forwarding Windows Event Logs to Graylog
# Generated by joe-speedboat.log_forwarder

winlogbeat.event_logs:
{% for log in winlogbeat_event_logs %}
  - name: {{ log.name }}
{% if log.level is defined and log.level %}
    level: {{ log.level }}
{% endif %}
{% if log.ignore_older is defined and log.ignore_older %}
    ignore_older: {{ log.ignore_older }}
{% endif %}
{% if log.event_ids is defined and log.event_ids %}
    processors:
      - drop_event.when.not.or:
{% for eid in log.event_ids %}
        - equals.event_id: {{ eid }}
{% endfor %}
{% endif %}
{% endfor %}

output.logstash:
  hosts: ["{{ winlogbeat_graylog_host }}:{{ winlogbeat_graylog_port }}"]
  bulk_max_size: 2048
  ssl.enabled: false
  # ssl.certificate_authorities: ["{{ winlogbeat_install_root }}/current/ca.pem"]
  # ssl.certificate: "{{ winlogbeat_install_root }}/current/client.crt"
  # ssl.key: "{{ winlogbeat_install_root }}/current/client.key"
  fields_under_root: true
  fields:
    log_type: winlogbeat
    journal_forwarder: "true"
{% if winlogbeat_fields is defined and winlogbeat_fields %}
  {{ winlogbeat_fields | to_nice_yaml(indent=2) | indent(2) }}
{% endif %}

processors:
  - add_host_metadata:
      netinfo.enabled: true

{% if winlogbeat_tags %}
tags: {{ winlogbeat_tags }}
{% endif %}

# Use forward slashes — Winlogbeat (Go-based) handles them on Windows
path.data: {{ winlogbeat_data_dir | replace('\\', '/') }}
path.logs: {{ winlogbeat_log_dir | replace('\\', '/') }}

logging.level: warning
logging.to_files: true
logging.files:
  path: {{ winlogbeat_log_dir | replace('\\', '/') }}
  name: winlogbeat.log
  keepfiles: 7
  rotateeverybytes: 10485760  # 10 MB

queue.mem:
  events: 4096
  flush.min_events: 512
  flush.timeout: 5s